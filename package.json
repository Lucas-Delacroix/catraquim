{
  "name": "catraquim",
  "version": "0.1.0",
  "description": "Local daemon to expose LLM CLIs as an OpenAI-compatible API.",
  "type": "module",
  "bin": {
    "catraquim": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --dts --clean",
    "check": "biome check .",
    "dev": "tsx scripts/dev.ts",
    "start": "tsx src/cli.ts start",
    "test": "vitest run"
  },
  "keywords": [
    "openai",
    "gateway",
    "hono",
    "codex",
    "oauth"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.8.1",
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.12",
    "pino": "^9.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.1",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
